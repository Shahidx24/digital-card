<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Digital Business Card</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); margin: 0; padding: 0; display: flex; justify-content: center; align-items: center; min-height: 100vh; }
        .card { background: white; width: 90%; max-width: 380px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.2); text-align: center; overflow: hidden; padding-bottom: 30px; }
        .header { background: #333; height: 100px; position: relative; }
        .avatar { width: 90px; height: 90px; background: #007bff; border-radius: 50%; border: 4px solid white; position: absolute; bottom: -45px; left: 50%; transform: translateX(-50%); display: flex; justify-content: center; align-items: center; color: white; font-size: 36px; font-weight: bold; }
        .info { margin-top: 55px; padding: 0 20px; }
        h1 { margin: 10px 0 5px 0; color: #333; font-size: 24px; }
        .title { color: #777; font-size: 14px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 20px; }
        .btn { display: flex; align-items: center; justify-content: center; background: #f1f3f5; color: #333; text-decoration: none; padding: 12px; margin: 10px 0; border-radius: 8px; font-weight: 600; transition: 0.2s; }
        .btn:hover { background: #007bff; color: white; }
        .btn-primary { background: #007bff; color: white; }
        .btn-primary:hover { background: #0056b3; }
    </style>
</head>
<body>

<div class="card">
    <div class="header">
        <div class="avatar" id="avatarInitials">U</div>
    </div>
    <div class="info">
        <h1 id="profName">User Name</h1>
        <div class="title" id="profRole">Profession</div>
        
        <a id="linkCall" href="#" class="btn btn-primary">📞 Call Mobile</a>
        <a id="linkEmail" href="#" class="btn">✉️ Email Me</a>
        <a id="linkWeb" href="#" class="btn" style="display:none;">🌐 Visit Website</a>
    </div>
</div>

<script>
    function getQueryParam(param) {
        const urlParams = new URLSearchParams(window.location.search);
        return decodeURIComponent(urlParams.get(param) || '');
    }

    const name = getQueryParam('name') || 'Valued Client';
    const role = getQueryParam('role') || 'Professional';
    const phone = getQueryParam('phone');
    const email = getQueryParam('email');
    const web = getQueryParam('web');

    document.getElementById('profName').innerText = name;
    document.getElementById('profRole').innerText = role;
    document.getElementById('avatarInitials').innerText = name.charAt(0).toUpperCase();

    if(phone) document.getElementById('linkCall').href = `tel:${phone}`;
    if(email) document.getElementById('linkEmail').href = `mailto:${email}`;
    
    if(web && web !== "undefined" && web !== "") {
        const webBtn = document.getElementById('linkWeb');
        webBtn.href = web;
        webBtn.style.display = 'flex';
    }
</script>

</body>
</html>
